{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "dist/**",
    "src/types/**",
    "**/*.md",
  ],
  "semi": true,
  "singleAttributePerLine": true,
  "singleQuote": true,
  "sortTailwindcss": true,
  "overrides": [
    {
      "files": ["**/*.html"],
      "options": {
        "singleAttributePerLine": false,
      }
    },
  ]
}
