{
  "name": "sbsp_frontend",
  "version": "2.5.3",
  "private": true,
  "license": "Elastic-2.0",
  "type": "module",
  "scripts": {
    "dev:web": "cross-env VITE_APP_TARGET=\"websocket\" vite --port 1424",
    "build:web": "cross-env VITE_APP_TARGET=\"websocket\" vite build",
    "dev:host": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"host\" vite",
    "dev:remote": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"remote\" vite",
    "build:host": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"host\" vite build",
    "build:remote": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"remote\" vite build",
    "typecheck": "run-s --continue-on-error typecheck:pre typecheck:exec typecheck:post",
    "typecheck:pre": "ts-patch uninstall",
    "typecheck:exec": "vue-tsc --build",
    "typecheck:post": "ts-patch install",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "prepare": "ts-patch install"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@primeuix/themes": "^2.0.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@vueuse/core": "^14.3.0",
    "jssha": "^3.3.2",
    "markdown-it": "^14.3.0",
    "markdown-it-link-attributes": "^4.0.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.3.2",
    "tailwindcss-primeui": "^0.6.1",
    "tinykeys": "^4.0.0",
    "typia": "^12.1.1",
    "uqr": "^0.1.3",
    "uuid": "^14.0.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^24.13.3",
    "@typia/unplugin": "^12.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.69.0",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "license-checker-rseidelsohn": "^5.0.1",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "~1.69.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "ts-patch": "^4.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.7"
  }
}
