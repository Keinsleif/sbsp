{
  "name": "sbsp_frontend",
  "license": "Elastic-2.0",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "cross-env VITE_APP_TARGET=\"websocket\" vite --port 1424",
    "build:web": "cross-env VITE_APP_TARGET=\"websocket\" vite build",
    "dev:host": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"host\" vite",
    "dev:remote": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"remote\" vite",
    "build:host": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"host\" vite build",
    "build:remote": "cross-env VITE_APP_TARGET=\"tauri\" VITE_APP_SIDE=\"remote\" vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "run-s --continue-on-error typecheck:pre typecheck:exec typecheck:post",
    "typecheck:pre": "ts-patch uninstall",
    "typecheck:exec": "vue-tsc --noEmit",
    "typecheck:post": "ts-patch install",
    "prepare": "ts-patch install"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@vueuse/core": "^14.3.0",
    "jssha": "^3.3.1",
    "markdown-it": "^14.2.0",
    "markdown-it-link-attributes": "^4.0.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "typia": "^12.1.1",
    "uqr": "^0.1.3",
    "uuid": "^14.0.0",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@mdi/js": "^7.4.47",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^25.9.1",
    "@typia/unplugin": "^12.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "npm-run-all2": "^9.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.100.0",
    "sass-loader": "^16.0.8",
    "ts-patch": "^4.0.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.1"
  }
}