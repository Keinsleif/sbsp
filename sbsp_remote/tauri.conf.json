{
  "$schema": "https://schema.tauri.app/config/2",
  "mainBinaryName": "sbsp_remote",
  "productName": "SBS Player Remote",
  "identifier": "com.keinsleif.sbsp.remote",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev:remote --port 1422",
      "cwd": "../sbsp_frontend"
    },
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": {
      "script": "pnpm build:remote",
      "cwd": "../sbsp_frontend"
    },
    "frontendDist": "../sbsp_frontend/dist/tauri/remote",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SBS Player Remote",
        "width": 1280,
        "height": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": ["https://fonts.gstatic.com"],
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self' 'nonce-aYxPbxuXswGq0ST6rvQ2AA=='",
        "style-src-elem": "'self' https://fonts.googleapis.com 'nonce-aYxPbxuXswGq0ST6rvQ2AA=='",
        "style-src-attr": "'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "dmg"],
    "resources": {
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    },
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "copyright": "© 2025 Keinsleif",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMkY0OTQ0RDk0NjA3MEMKUldRTUIwYlpSRWt2RXYwbkRpT0ZDTWhKcnN2ZS9zMFFDSEFyeTkxR2w3STlEY2Rrckk5cHcyc1IK",
      "endpoints": [
        "https://keinsleif.github.io/sbsp/update/latest-remote.json"
      ]
    }
  }
}
