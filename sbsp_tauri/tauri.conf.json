{
  "$schema": "https://schema.tauri.app/config/2",
  "mainBinaryName": "sbsp_tauri",
  "productName": "SBS Player",
  "identifier": "com.keinsleif.sbsp",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev:host",
      "cwd": "../sbsp_frontend"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "pnpm build:host",
      "cwd": "../sbsp_frontend"
    },
    "frontendDist": "../sbsp_frontend/dist/tauri/host",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SBS Player",
        "width": 1280,
        "height": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": ["https://fonts.gstatic.com"],
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "script-src": "'self' 'nonce-aYxPbxuXswGq0ST6rvQ2AA=='",
        "worker-src": "'self' blob:",
        "style-src-elem": "'self' https://fonts.googleapis.com 'nonce-aYxPbxuXswGq0ST6rvQ2AA=='",
        "style-src-attr": "'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "dmg"],
    "resources": {
      "../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md",
      "../sbsp_frontend/dist/websocket": "websocket"
    },
    "createUpdaterArtifacts": true,
    "category": "Music",
    "copyright": "© 2025 Keinsleif",
    "publisher": "Keinsleif",
    "shortDescription": "A SBS Player Frontend App powered by tauri.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzNDAzRDM2OERDRTJCQjQKUldTMEs4Nk5OajFBUTBFZ2ZCcnBOdXZQUi9WQXRTVmZWRHgxbk45QnJzZW9MRFR0ME83UnQ1clUK",
      "endpoints": [
        "https://keinsleif.github.io/sbsp/update/latest-main.json"
      ]
    }
  }
}
